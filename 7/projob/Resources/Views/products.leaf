<!doctype html>
<html lang="en">
<head>
	<meta charset="utf-8">
	<title>#(name)</title>
</head>

<body>
	<h1>#count(products) Products:</h1>
	#for(product in products):
	<section>
		<h2>#(product.name)</h2>
		<code>#(product.id)</code>
		<p>#(product.description)</p>
		<p>#(product.price)¤</p>
	</section>
	#endfor
</body>
</html>
